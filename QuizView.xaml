<UserControl x:Class="CyberChatBot.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CyberChatBot.App.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Quiz Header -->
        <Border Grid.Row="0" Background="#E67E22" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📝" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Cybersecurity Quiz" FontSize="20" Foreground="White" FontWeight="Bold"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding QuizProgress}" FontSize="16" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,15,0"/>

                <Border Grid.Column="2" Background="White" Padding="10,5" CornerRadius="20">
                    <TextBlock Text="{Binding ScoreText}" FontWeight="Bold" FontSize="14"/>
                </Border>
            </Grid>
        </Border>

        <!-- Question Area and Result (Stacked) -->
        <Grid Grid.Row="1">
            <!-- Question Area -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="20"
                    Visibility="{Binding ShowResult, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapse}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Question -->
                    <TextBlock Grid.Row="0" Text="{Binding CurrentQuestion}" FontSize="18" FontWeight="SemiBold" 
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Options -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CurrentOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="QuizOptions" Content="{Binding}" Margin="0,5" FontSize="15"
                                             Command="{Binding DataContext.SelectOptionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                             CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Feedback -->
                    <Border Grid.Row="2" Background="{Binding FeedbackColor}" Padding="15" CornerRadius="5" 
                            Visibility="{Binding ShowFeedback, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapse}"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding FeedbackText}" FontSize="16" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Explanation}" FontSize="13" Foreground="White" 
                                       TextWrapping="Wrap" Margin="0,5,0,0" 
                                       Visibility="{Binding ShowExplanation, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapse}"/>
                        </StackPanel>
                    </Border>

                    <!-- Next Button -->
                    <Button Grid.Row="3" Content="Next Question →" Width="150" Height="40" Background="#3498DB"
                            Command="{Binding NextQuestionCommand}" Margin="0,20,0,0"
                            Visibility="{Binding ShowNextButton, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapse}"/>
                </Grid>
            </Border>

            <!-- Quiz Result -->
            <Border Background="#F5F5F5" Padding="30" CornerRadius="5" 
                    Visibility="{Binding ShowResult, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapse}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResultTitle}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" 
                               Foreground="{Binding ResultColor}"/>
                    <TextBlock Text="{Binding ResultScore}" FontSize="20" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding ResultMessage}" FontSize="16" Foreground="#666" 
                               TextWrapping="Wrap" Width="400" TextAlignment="Center" Margin="0,0,0,25"/>
                    <Button Content="🔄 Retry Quiz" Width="150" Height="45" Background="#E67E22" 
                            Command="{Binding ResetQuizCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>